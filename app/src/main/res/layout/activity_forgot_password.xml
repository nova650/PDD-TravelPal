<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0C15"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="Reset Password"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_forgot_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:alpha="0.8"
                android:text="Verify your registered email address."
                android:textColor="#8B5CF6"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Forgot Password Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="4dp">

                <!-- STATE 1: EMAIL VERIFICATION -->
                <LinearLayout
                    android:id="@+id/layout_forgot_state_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verification Email"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter your email to retrieve your security question."
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#1E293B"
                        app:hintTextColor="#94A3B8"
                        app:startIconDrawable="@drawable/ic_email_outline"
                        app:startIconTint="#94A3B8">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/et_forgot_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            android:inputType="textEmailAddress"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Verify Email Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_forgot_verify_email"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_logo_gradient"
                        android:text="Continue"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- STATE 2: SECURITY QUESTION ANSWERING -->
                <LinearLayout
                    android:id="@+id/layout_forgot_state_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Answer Security Question"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Answer the recovery question to reset your password."
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Question display -->
                    <TextView
                        android:id="@+id/tv_forgot_question_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:textColor="#8B5CF6"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Question: What is your mother's maiden name?" />

                    <!-- Answer Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#1E293B"
                        app:hintTextColor="#94A3B8">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/et_forgot_answer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Your Answer"
                            android:inputType="text"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Verify Answer Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_forgot_verify_answer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_logo_gradient"
                        android:text="Verify Answer"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />
                </LinearLayout>

                <!-- STATE 3: NEW PASSWORD RESET -->
                <LinearLayout
                    android:id="@+id/layout_forgot_state_reset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set New Password"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose a strong, memorable new password."
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- New Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#1E293B"
                        app:hintTextColor="#94A3B8"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#94A3B8"
                        app:startIconDrawable="@drawable/ic_lock_outline"
                        app:startIconTint="#94A3B8">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/et_forgot_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="New Password"
                            android:inputType="textPassword"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm New Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:boxBackgroundColor="#0F172A"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#1E293B"
                        app:hintTextColor="#94A3B8"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="#94A3B8"
                        app:startIconDrawable="@drawable/ic_lock_outline"
                        app:startIconTint="#94A3B8">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/et_forgot_confirm_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Confirm New Password"
                            android:inputType="textPassword"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Reset Password Button -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_forgot_reset_password"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_logo_gradient"
                        android:text="Reset Password"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />
                </LinearLayout>

            </LinearLayout>

            <!-- Navigation back to Login -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_forgot_back_to_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back to Log In"
                    android:textColor="#8B5CF6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
