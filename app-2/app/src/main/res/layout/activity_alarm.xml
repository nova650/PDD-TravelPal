<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".activities.Alarm">

    <!-- Amber accent top band -->
    <View android:layout_width="match_parent" android:layout_height="4dp"
        android:background="@color/colorPrimary"
        android:layout_marginBottom="0dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DESTINATION REACHED!"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You have arrived"
            android:textColor="@color/secondary_text_color"
            android:gravity="center"
            android:textSize="16sp"
            android:layout_marginBottom="28dp"/>

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:srcCompat="@raw/duck_walk"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/colorPrimary"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"/>

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            app:srcCompat="@drawable/ic_baseline_keyboard_arrow_up_24"
            app:tint="@color/colorPrimary"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Swipe up to dismiss"
            android:gravity="center"
            android:textColor="@color/secondary_text_color"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</LinearLayout>
